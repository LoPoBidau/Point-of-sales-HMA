<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:orientation="vertical" android:padding="16dp"
    android:layout_width="match_parent" android:layout_height="wrap_content">

    <RadioGroup
        android:id="@+id/rgMode"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:orientation="horizontal">
        <RadioButton android:id="@+id/rbAdd" android:checked="true"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Tambah" />
        <RadioButton android:id="@+id/rbSub"
            android:layout_marginStart="24dp"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Kurangi" />
    </RadioGroup>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilQty"
        android:layout_width="match_parent" android:layout_height="wrap_content">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etQty"
            android:inputType="number"
            android:hint="Qty"
            android:layout_width="match_parent" android:layout_height="wrap_content"/>
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilAdjUnitCost"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:hint="Harga modal per unit (Rp) — untuk Tambah"
        android:visibility="gone">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etAdjUnitCost"
            android:inputType="number"
            android:layout_width="match_parent" android:layout_height="wrap_content"/>
    </com.google.android.material.textfield.TextInputLayout>

    <com.google.android.material.textfield.TextInputLayout
        android:id="@+id/tilReason"
        android:layout_width="match_parent" android:layout_height="wrap_content"
        android:layout_marginTop="8dp">
        <com.google.android.material.textfield.TextInputEditText
            android:id="@+id/etReason" android:hint="Alasan"
            android:layout_width="match_parent" android:layout_height="wrap_content"/>
    </com.google.android.material.textfield.TextInputLayout>
</LinearLayout>
